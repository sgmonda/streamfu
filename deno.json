{
  "name": "@sgmonda/streamfu",
  "description": "Functional programming utilities for working with streams in JS/TS",
  "version": "0.8.0",
  "license": "MIT",
  "exports": {
    ".": "./mod.ts",
    "./at": "./src/at.ts",
    "./batch": "./src/batch.ts",
    "./branch": "./src/branch.ts",
    "./concat": "./src/concat.ts",
    "./count": "./src/count.ts",
    "./createReadable": "./src/createReadable.ts",
    "./createWritable": "./src/createWritable.ts",
    "./drop": "./src/drop.ts",
    "./every": "./src/every.ts",
    "./filter": "./src/filter.ts",
    "./flat": "./src/flat.ts",
    "./flatMap": "./src/flatMap.ts",
    "./forEach": "./src/forEach.ts",
    "./includes": "./src/includes.ts",
    "./indexOf": "./src/indexOf.ts",
    "./iterate": "./src/generators/iterate.ts",
    "./join": "./src/join.ts",
    "./lines": "./src/lines.ts",
    "./list": "./src/list.ts",
    "./map": "./src/map.ts",
    "./merge": "./src/merge.ts",
    "./pipe": "./src/pipe.ts",
    "./range": "./src/generators/range.ts",
    "./reduce": "./src/reduce.ts",
    "./slice": "./src/slice.ts",
    "./some": "./src/some.ts",
    "./splice": "./src/splice.ts",
    "./take": "./src/take.ts",
    "./tap": "./src/tap.ts",
    "./toBuffer": "./src/toBuffer.ts",
    "./words": "./src/generators/words.ts",
    "./zip": "./src/zip.ts"
  },
  "imports": {
    "streams": "jsr:@std/streams",
    "asserts": "jsr:@std/assert",
    "fast-check": "npm:fast-check@3"
  },
  "tasks": {
    "check": "deno check src/**/*.ts *.ts",
    "lint": "deno fmt && deno lint src/**/*.ts *.ts",
    "test": {
      "command": "rm -Rf coverage && deno test --allow-all --coverage --ignore=examples/bun,examples/cloudflare-workers && deno task test:examples && deno coverage --exclude=src/system --exclude=examples",
      "dependencies": ["check", "lint"]
    },
    "test:examples": "deno task test:examples:deno && deno task test:examples:node && deno task test:examples:bun && deno task test:examples:cloudflare-workers",
    "test:examples:node": "cd ./examples/node && npm test && npx -y yarn test && npx -y pnpm test",
    "test:examples:deno": "cd ./examples/deno && deno test --allow-all",
    "test:examples:bun": "cd ./examples/bun && bun test",
    "test:examples:cloudflare-workers": "cd ./examples/cloudflare-workers && npm test",
    "site": "cd docs && bundle exec jekyll serve --livereload"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 120,
    "indentWidth": 2,
    "semiColons": false,
    "singleQuote": false,
    "proseWrap": "preserve",
    "exclude": ["docs/"]
  },
  "lint": { "rules": { "tags": ["fresh", "recommended"] } }
}
